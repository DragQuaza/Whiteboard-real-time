{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/config.js",
      "destination": "/api/config.js"
    },
    {
      "source": "/runtime-config.js",
      "destination": "/api/runtime-config"
    },
    {
      "source": "/room/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/room",
      "destination": "/",
      "permanent": false
    }
  ]
}
